# ============================================================================
# TekyPro LMS - Backend Environment Variables
# ============================================================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control
# ============================================================================

# Application
NODE_ENV=development
PORT=5000
APP_NAME=TekyPro LMS
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174

# Database Configuration
# SECURITY: Use strong database credentials in production
# For Docker deployments, also set DB_ROOT_PASSWORD
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tekypro_lms
DB_USER=your_db_user
DB_PASSWORD=your_secure_db_password_here
DB_ROOT_PASSWORD=your_secure_root_password_here
DB_DIALECT=mysql

# Database Pool Settings
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT Configuration
# SECURITY: Generate strong random secrets using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_64_byte_random_hex_string_here
JWT_REFRESH_SECRET=generate_a_different_64_byte_random_hex_string_here
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Google OAuth 2.0
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Cloudinary Configuration
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration
# For Gmail: Enable 2FA and create App Password
# For other SMTP: Use your provider's settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_or_smtp_password
EMAIL_FROM=TekyPro LMS <noreply@tekypro.com>

# Rate Limiting
# Adjust based on expected traffic
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# File Upload
# Size in bytes (10485760 = 10MB)
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,jpg,jpeg,png,mp4,webm

# Logging
# Options: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Session
# SECURITY: Generate a strong random secret using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=generate_a_64_byte_random_hex_string_for_sessions

# Certificate Generation
CERTIFICATE_ISSUER=TekyPro - The Leading Remote DBA Service Provider
CERTIFICATE_URL=https://www.tekypro.com

# Redis Cache Configuration
# IMPORTANT: Redis is now REQUIRED for token blacklist functionality
# SECURITY: Always set a strong Redis password in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_DB=0

# Performance
ENABLE_COMPRESSION=true
COMPRESSION_LEVEL=6

# Monitoring (Grafana)
# SECURITY: Change default Grafana admin password
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_secure_grafana_password_here

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production, ensure:
#
# 1. NODE_ENV=production
# 2. All secrets are rotated and stored in secure secrets manager
# 3. Database credentials use least-privilege principle
# 4. JWT secrets are strong random values (minimum 64 bytes)
# 5. CORS origins are restricted to your actual domains
# 6. Rate limiting is appropriately configured
# 7. Email service is configured and tested
# 8. Cloudinary or file storage is configured
# 9. Redis is enabled and secured (if using caching)
# 10. All credentials are stored in environment variables, not in code
#
# NEVER use default/example values in production!
# ============================================================================
