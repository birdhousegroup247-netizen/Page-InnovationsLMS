# ============================================================================
# Page Innovation LMS - Backend Environment Variables
# ============================================================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control
# ============================================================================

# Application
NODE_ENV=development
PORT=5000
APP_NAME=Page Innovation LMS
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174

# Database Configuration
# SECURITY: Use strong database credentials in production
# For Docker deployments, also set DB_ROOT_PASSWORD
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pageinnovation_lms
DB_USER=your_db_user
DB_PASSWORD=your_secure_db_password_here
DB_ROOT_PASSWORD=your_secure_root_password_here
DB_DIALECT=mysql

# Database Pool Settings
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT Configuration
# SECURITY: Generate strong random secrets using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_64_byte_random_hex_string_here
JWT_REFRESH_SECRET=generate_a_different_64_byte_random_hex_string_here
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Google OAuth 2.0
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Cloudinary Configuration
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration
# For Gmail: Enable 2FA and create App Password
# For other SMTP: Use your provider's settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_or_smtp_password
EMAIL_FROM=Page Innovation LMS <noreply@pageinnovation.com>

# ============================================================================
# STRIPE PAYMENT PROCESSING
# ============================================================================
# Get keys from: https://dashboard.stripe.com/apikeys
# Use sk_test_* / pk_test_* for development, sk_live_* / pk_live_* for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# Get webhook secret from: https://dashboard.stripe.com/webhooks
# After creating the webhook endpoint pointing to: https://yourdomain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ============================================================================
# PAYPAL PAYMENT PROCESSING (PRIMARY GATEWAY)
# ============================================================================
# Create app at https://developer.paypal.com/dashboard/applications
# PAYPAL_MODE: "sandbox" for testing, "live" for production payments
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
# After creating a webhook at https://developer.paypal.com/dashboard/webhooks
# pointing to https://yourdomain.com/api/webhooks/paypal
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# ============================================================================
# MAILCHIMP (Email Drip Campaigns)
# ============================================================================
# Get API key from: https://mailchimp.com/help/about-api-keys/
# Server prefix is the last part of your API key (e.g. us21)
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_SERVER_PREFIX=us21
# Get List/Audience ID from: Mailchimp > Audience > Settings > Audience name and defaults
MAILCHIMP_LIST_ID=your_audience_list_id_here

# ============================================================================
# TWILIO (WhatsApp Notifications)
# ============================================================================
# Get credentials from: https://console.twilio.com/
# WhatsApp number requires WhatsApp Business approval from Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ============================================================================
# INSTALLMENT PAYMENT SETTINGS (Countdown Lock System)
# ============================================================================
# Number of days after payment before installment balance is due
INSTALLMENT_DUE_DAYS=21
# Days past due date for each lock stage
INSTALLMENT_ORANGE_BANNER_DAY=3
INSTALLMENT_RED_BANNER_DAY=7
INSTALLMENT_PARTIAL_LOCK_DAY=11
INSTALLMENT_SOFT_LOCK_DAY=14
INSTALLMENT_HARD_LOCK_DAY=21

# Rate Limiting
# Adjust based on expected traffic
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# File Upload
# Size in bytes (10485760 = 10MB)
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,jpg,jpeg,png,mp4,webm

# Logging
# Options: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Session
# SECURITY: Generate a strong random secret using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=generate_a_64_byte_random_hex_string_for_sessions

# Certificate Generation
CERTIFICATE_ISSUER=Page Innovation - The Leading Remote DBA Service Provider
CERTIFICATE_URL=https://www.pageinnovation.com

# Redis Cache Configuration
# IMPORTANT: Redis is now REQUIRED for token blacklist functionality
# SECURITY: Always set a strong Redis password in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_DB=0

# Performance
ENABLE_COMPRESSION=true
COMPRESSION_LEVEL=6

# Monitoring (Grafana)
# SECURITY: Change default Grafana admin password
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_secure_grafana_password_here

# Prometheus Scrape Token
# Used by Prometheus to authenticate against the /metrics endpoint.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# After setting, also run: echo -n "$PROMETHEUS_TOKEN" > prometheus_scrape_token
PROMETHEUS_TOKEN=generate_a_random_token_here

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production, ensure:
#
# 1. NODE_ENV=production
# 2. All secrets are rotated and stored in secure secrets manager
# 3. Database credentials use least-privilege principle
# 4. JWT secrets are strong random values (minimum 64 bytes)
# 5. CORS origins are restricted to your actual domains
# 6. Rate limiting is appropriately configured
# 7. Email service is configured and tested
# 8. Cloudinary or file storage is configured
# 9. Redis is enabled and secured (if using caching)
# 10. All credentials are stored in environment variables, not in code
# 11. STRIPE_SECRET_KEY is using live key (sk_live_*)
# 12. STRIPE_WEBHOOK_SECRET is set and webhook endpoint is registered in Stripe dashboard
# 13. Stripe webhook URL points to: https://yourdomain.com/api/webhooks/stripe
# 14. Mailchimp API key and list ID are configured
# 15. Twilio credentials set if using WhatsApp notifications
#
# NEVER use default/example values in production!
# ============================================================================
