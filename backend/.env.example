# ============================================================================
# TekyPro LMS - Backend Environment Variables (Example)
# ============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace all placeholder values with your actual credentials
# 3. NEVER commit .env file to git
#
# ============================================================================

# Application
NODE_ENV=development
PORT=5000
APP_NAME=TekyPro LMS
FRONTEND_URL=http://localhost:3000

# Database Configuration
# ⚠️ Change these values for your MySQL installation
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tekypro_lms
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_DIALECT=mysql

# Database Pool Settings
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT Configuration
# ⚠️ Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_strong_secret_key_minimum_64_characters_use_crypto_randomBytes
JWT_REFRESH_SECRET=generate_a_different_strong_secret_key_minimum_64_characters
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Google OAuth 2.0
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Cloudinary (File Storage)
# Sign up at: https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Configuration (Gmail SMTP)
# Use App-Specific Password: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-character-app-specific-password
EMAIL_FROM=TekyPro LMS <noreply@tekypro.com>

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,jpg,jpeg,png

# Logging
LOG_LEVEL=info

# Session
# ⚠️ Generate strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=generate_a_strong_session_secret_minimum_64_characters

# Certificate Generation
CERTIFICATE_ISSUER=TekyPro - The Leading Remote DBA Service Provider
CERTIFICATE_URL=https://www.tekypro.com

# Redis Cache Configuration
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Performance
ENABLE_COMPRESSION=true
COMPRESSION_LEVEL=6
