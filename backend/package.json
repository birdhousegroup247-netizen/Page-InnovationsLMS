{
  "name": "pageinnovation-lms-backend",
  "version": "1.0.0",
  "description": "Page Innovation LMS - Backend API for Learning Management System",
  "main": "server.js",
  "scripts": {
    "start": "export RATE_LIMIT_SKIP_VALIDATION=true && node server.js",
    "server": "nodemon server.js",
    "client": "npm start --prefix client",
    "dev": "npm run server",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPatterns=__tests__/unit",
    "test:integration": "jest --testPathPatterns=__tests__/integration",
    "seed": "node scripts/seedDatabase.js",
    "seed:reset": "node scripts/seedDatabase.js --reset"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/config/",
      "/migrations/"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  },
  "keywords": [
    "lms",
    "learning",
    "database",
    "training",
    "pageinnovation"
  ],
  "author": "Page Innovation - The Leading Remote DBA Service Provider",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-prom-bundle": "^8.0.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "fast-csv": "^5.0.7",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.2.1",
    "json2csv": "^5.0.7",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.12.1",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "ws": "^8.20.1"
  }
}
