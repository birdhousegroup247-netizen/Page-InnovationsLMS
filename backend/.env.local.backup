JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Google OAuth 2.0 (Setup later)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Cloudinary (Setup later)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
