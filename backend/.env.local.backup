# Email Configuration (Setup later)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=TekyPro LMS <noreply@tekypro.com>

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5000

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,jpg,jpeg,png

# Logging
LOG_LEVEL=info

# Session
SESSION_SECRET=992a1cb94b76ad082d0e2d093267877087859ec5c35f95ae5ab8b27fdddd5e0c7b25be5e0376eeb25f0f7fab34e1943eeb5979fbb2e15e2eb77485b1235702e9

# Certificate Generation
CERTIFICATE_ISSUER=TekyPro - The Leading Remote DBA Service Provider
