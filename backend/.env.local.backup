# Application
NODE_ENV=development
PORT=5000
APP_NAME=TekyPro LMS
FRONTEND_URL=http://localhost:5175

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tekypro_lms
DB_USER=root
DB_PASSWORD=Sunmboye@1
DB_DIALECT=mysql

# Database Pool Settings
DB_POOL_MAX=5
DB_POOL_MIN=0
