DB_POOL_IDLE=10000

# JWT Configuration
JWT_SECRET=3b938607813a8754c46daa65df309120d379c37fa7e9f6af7df285d0a1183e8ebafa5ce3560c4fef5e83fe10bf8f5fbab726fcad2c9a7a8a6582efe4020038d4
