# ============================================================================
# TekyPro LMS - Docker Compose Environment Variables
# ============================================================================
# IMPORTANT: Copy this file to .env in the root directory and fill in secure values
# This file is specifically for docker-compose.yml configuration
# ============================================================================

# ============================================================================
# SECURITY: GENERATE STRONG PASSWORDS BEFORE USING
# ============================================================================
# Use these commands to generate secure passwords:
#
# For general passwords (32 bytes):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# For JWT secrets (64 bytes):
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================================

# Database Credentials
# REQUIRED: Must be set before running docker-compose
DB_NAME=tekypro_lms
DB_USER=tekypro_user
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD_HERE
DB_ROOT_PASSWORD=CHANGE_ME_TO_SECURE_ROOT_PASSWORD_HERE

# Redis Password
# REQUIRED: Must be set before running docker-compose
REDIS_PASSWORD=CHANGE_ME_TO_SECURE_REDIS_PASSWORD_HERE

# JWT Secrets
# REQUIRED: Generate using the commands above (64 bytes recommended)
JWT_SECRET=CHANGE_ME_TO_64_BYTE_RANDOM_HEX_STRING_HERE
JWT_REFRESH_SECRET=CHANGE_ME_TO_DIFFERENT_64_BYTE_RANDOM_HEX_STRING_HERE

# Frontend URLs
# Update these to match your deployment environment
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174
VITE_API_URL=http://localhost:5000/api

# Grafana Admin Password
# REQUIRED: Must be set before running docker-compose
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_TO_SECURE_GRAFANA_PASSWORD_HERE

# ============================================================================
# QUICK START GUIDE
# ============================================================================
#
# 1. Copy this file to .env in the root directory:
#    cp .env.docker.example .env
#
# 2. Generate secure passwords using Node.js:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    (Run this command 4 times for DB_PASSWORD, DB_ROOT_PASSWORD, REDIS_PASSWORD, GRAFANA_PASSWORD)
#
# 3. Generate JWT secrets (64 bytes):
#    node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#    (Run this command 2 times for JWT_SECRET and JWT_REFRESH_SECRET)
#
# 4. Replace all CHANGE_ME values in .env with the generated passwords
#
# 5. Start the stack:
#    docker-compose up -d
#
# 6. Check health:
#    curl http://localhost:5000/health
#
# ============================================================================

# ============================================================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================================================
#
# For production:
# - Use a secrets manager (AWS Secrets Manager, Azure Key Vault, HashiCorp Vault)
# - Never commit .env file to version control
# - Use minimum 32-byte passwords (64 characters hex)
# - Use minimum 64-byte JWT secrets (128 characters hex)
# - Enable SSL/TLS for all services
# - Restrict network access to databases
# - Enable database backups
# - Set up log aggregation and monitoring
# - Configure alerting for critical metrics
#
# ============================================================================
