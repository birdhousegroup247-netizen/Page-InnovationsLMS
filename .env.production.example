# ============================================================================
# TekyPro LMS - Production Environment Variables for Render.com
# ============================================================================
# IMPORTANT: These are the environment variables you need to set in Render.com
# Copy these variable names to your Render.com service environment variables
# ============================================================================

# Application
NODE_ENV=production
PORT=5000

# Frontend URLs (Render.com URLs)
FRONTEND_URL=https://tekypro-student.onrender.com
ADMIN_FRONTEND_URL=https://tekypro-admin.onrender.com

# Database Configuration
# NOTE: Render.com provides these automatically via DATABASE_URL
# You can also use individual connection parameters
# DB_HOST will be provided by Render
# DB_PORT will be provided by Render (PostgreSQL uses 5432)
# DB_NAME will be provided by Render
# DB_USER will be provided by Render
# DB_PASSWORD will be provided by Render
DB_DIALECT=postgres

# Database Pool Settings
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT Configuration
# IMPORTANT: Generate strong random secrets using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Set these as SECRETS in Render.com dashboard
JWT_SECRET=<GENERATE_64_BYTE_HEX_STRING>
JWT_REFRESH_SECRET=<GENERATE_DIFFERENT_64_BYTE_HEX_STRING>
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Session Secret
# IMPORTANT: Generate using same method as JWT secrets
SESSION_SECRET=<GENERATE_64_BYTE_HEX_STRING>

# Google OAuth 2.0 (Optional - configure if using Google login)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Update callback URL to: https://tekypro-api.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://tekypro-api.onrender.com/api/auth/google/callback

# Cloudinary Configuration (Required for file uploads)
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (Required for notifications)
# For Gmail: Enable 2FA and create App Password
# For SendGrid: Use API key as password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=TekyPro LMS <noreply@tekypro.com>

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,jpg,jpeg,png,mp4,webm

# Logging
LOG_LEVEL=info

# Certificate Generation
CERTIFICATE_ISSUER=TekyPro - The Leading Remote DBA Service Provider
CERTIFICATE_URL=https://www.tekypro.com

# Redis Cache Configuration
# IMPORTANT: Render.com free tier doesn't include Redis
# You need to disable Redis for free deployment
REDIS_ENABLED=false

# If you have Redis (paid tier), configure these:
# REDIS_HOST=your-redis-host.onrender.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
# REDIS_DB=0

# Performance
ENABLE_COMPRESSION=true
COMPRESSION_LEVEL=6

# ============================================================================
# RENDER.COM DEPLOYMENT NOTES
# ============================================================================
#
# 1. Database:
#    - Render provides PostgreSQL (not MySQL) on free tier
#    - DATABASE_URL is automatically injected
#    - Make sure DB_DIALECT=postgres
#
# 2. Secrets to Generate:
#    Run these commands locally and copy the output:
#    - JWT_SECRET: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#    - JWT_REFRESH_SECRET: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#    - SESSION_SECRET: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# 3. Redis:
#    - Set REDIS_ENABLED=false for free tier
#    - Rate limiting will use in-memory store
#    - This is acceptable for demo/small scale
#
# 4. File Uploads:
#    - Configure Cloudinary (free tier available)
#    - Or disable file uploads temporarily
#
# 5. Email:
#    - Configure SMTP or use free tier service like SendGrid
#    - Or disable email notifications temporarily
#
# ============================================================================
