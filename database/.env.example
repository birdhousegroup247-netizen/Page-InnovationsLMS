# ============================================================================
# TekyPro LMS - Database Configuration
# ============================================================================

# Database Type
DB_DIALECT=mysql
# Options: mysql, mssql, postgres

# MySQL Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tekypro_lms
DB_USER=root
DB_PASSWORD=your_password_here

# MSSQL Server Configuration (Alternative)
# DB_DIALECT=mssql
# DB_HOST=localhost
# DB_PORT=1433
# DB_NAME=tekypro_lms
# DB_USER=sa
# DB_PASSWORD=your_password_here

# Connection Pool Settings
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Database Options
DB_CHARSET=utf8mb4
DB_COLLATE=utf8mb4_unicode_ci
DB_TIMEZONE=+00:00

# Logging
DB_LOGGING=false
# Set to true for development to see SQL queries

# ============================================================================
# Production Database (Railway/Render)
# ============================================================================
# DATABASE_URL=mysql://user:password@host:port/database
# This will override individual DB_* settings if provided
